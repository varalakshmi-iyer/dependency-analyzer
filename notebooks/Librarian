def extract_processor_profile(processor_id, processor_name,
                               role, doc_labels, code_constraints):
    combined = ""
    for label in doc_labels:
        if label in documents:
            combined += f"\n\n--- {label} ---\n{documents[label][:4000]}"

    if not combined:
        print(f"  ⚠️  No documents for {processor_name}")
        return None

    prompt = PROCESSOR_PROFILE_PROMPT.format(
        processor_id   = processor_id,
        processor_name = processor_name,
        role           = role,
        doc_text       = combined[:8000],
        code_constraints = "\n".join(f"- {c}" for c in code_constraints[:20]),
    )
    try:
        response = model.generate_content(prompt, generation_config=gen_config)
        raw = response.text.strip()
        raw = re.sub(r"^```(?:json)?\s*\n?", "", raw)
        raw = re.sub(r"\n?```\s*$", "", raw)
        result = json.loads(raw)
        result["processor_id"]   = processor_id
        result["processor_name"] = processor_name
        result["role"]           = role
        return result
    except Exception as e:
        print(f"  ❌ {e}")
        return None


