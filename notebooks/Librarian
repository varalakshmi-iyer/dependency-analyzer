  "match_strength":    "exact | partial | inferred | none",
  "matched_req_ids":   ["REQ-001"],
  "match_explanation": "why this matches",
  "gap":               false,
  "gap_reason":        "null if matched, else why no doc evidence",
  "is_ghost_rule_confirmed": false,
  "ghost_rule_doc_evidence": "quote or null",
  "processor_delta":   false,
  "processor_delta_detail": "null or description of A vs B difference",
  "recommendation":    "PROCEED | SME_REVIEW | VENDOR_VERIFY | DOCUMENT_FIRST"
}}

Respond ONLY with valid JSON. No markdown fences."""


def match_constraint_to_requirements(node_name, file_path,
                                      constraint, all_requirements, glossary):
    prompt = MATCH_PROMPT.format(
        node_name            = node_name,
        file_path            = file_path,
        constraint_statement = constraint.get("statement", ""),
        constraint_type      = constraint.get("type", ""),
        is_ghost             = constraint.get("is_ghost_rule", False),
        ghost_reason         = constraint.get("ghost_reason", "None"),
        confidence           = constraint.get("confidence", ""),
        requirements_text    = format_requirements_for_prompt(all_requirements),
        glossary_text        = format_glossary_for_prompt(glossary),
    )
    try:
        response = model.generate_content(prompt, generation_config=gen_config)
        raw = response.text.strip()
        raw = re.sub(r"^```(?:json)?\s*\n?", "", raw)
        raw = re.sub(r"\n?```\s*$", "", raw)
        return json.loads(raw)
    except Exception as e:
        print(f"    ❌ Match error: {e}")
        return None


