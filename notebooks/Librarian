def format_requirements_for_prompt(reqs, max_reqs=20):
    return "\n".join(
        f"  {r['req_id']} [{r['category']}] ({r['source_label']}): {r['statement']}"
        for r in reqs[:max_reqs]
    )

def format_glossary_for_prompt(glossary, max_terms=15):
    return "\n".join(
        f"  {term}: {data['definition']}"
        for term, data in list(glossary.items())[:max_terms]
    )


