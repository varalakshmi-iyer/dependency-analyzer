SECRET_PATTERNS = [
    (re.compile(r"(?i)(api[_-]?key|token|password)\s*[=:]\s*['\"]?([A-Za-z0-9\-_]{16,})['\"]?"), "SECRET"),
    (re.compile(r"-----BEGIN (RSA )?PRIVATE KEY-----"), "PRIVATE_KEY"),
    (re.compile(r"ghp_[A-Za-z0-9]{36}"), "GITHUB_TOKEN"),
]

def sanitise(text: str) -> str:
    for pattern, label in SECRET_PATTERNS:
        text = pattern.sub(f"[{label}_REDACTED]", text)
    return text

def fetch_url(url: str) -> str:
    try:
        req = urllib.request.Request(
            url, headers={"User-Agent": "Librarian-Agent/1.0"}
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            raw = re.sub(r"<style[^>]*>.*?</style>", "", raw, flags=re.DOTALL)
            raw = re.sub(r"<script[^>]*>.*?</script>", "", raw, flags=re.DOTALL)
            raw = re.sub(r"<[^>]+>", " ", raw)
            raw = re.sub(r"\s+", " ", raw).strip()
            return sanitise(raw[:20000])
    except Exception as e:
        print(f"  ⚠️  Could not fetch {url}: {e}")
        return ""

def load_documents(sources: list) -> Dict[str, str]:
    docs = {}
    for label, dtype, content in sources:
        print(f"  Loading [{dtype}] {label}...", end=" ")
        if dtype == "url":
            text = fetch_url(content)
        elif dtype == "text":
            text = sanitise(content.strip())
        elif dtype in ("confluence", "jira"):
            text = fetch_url(content)
        else:
            text = content
        docs[label] = text
        print(f"✅ {len(text)} chars")
    return docs

