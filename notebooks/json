      "is_entry_point": true/false,
      "ghost_rule_risk": true/false,
      "ghost_rule_reason": "<reason or null>"
    }}
  ],
  "module_summary": "<2 sentences on what this file does>",
  "business_domain": "<e.g. payment processing, account management>"
}}

Respond ONLY with valid JSON."""

def annotate_with_gemini(path, language, code, nodes):
    if not GEMINI_API_KEY or GEMINI_API_KEY == "your-key-here":
        print("⚠️  No API key — skipping LLM annotation")
        return None

    units = "\n".join(f"- {n['name']} ({n['type']}) line {n['line']}" for n in nodes[:20])
    prompt = PROMPT_TEMPLATE.format(
        path=path, language=language,
        code=code[:4000], units=units
    )

    payload = json.dumps({
        "contents": [{"role": "user", "parts": [{"text": prompt}]}],
        "generationConfig": {"temperature": 0.0, "maxOutputTokens": 2048}
    }).encode()

    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={GEMINI_API_KEY}"
    req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json"})

    with urllib.request.urlopen(req, timeout=60) as resp:
