def build_structural_map(repo_url, clone_dir, files, annotated_results, max_files=20):
    artifact = {
        "artifact_id":           hashlib.md5(repo_url.encode()).hexdigest()[:12],
        "repo_url":              repo_url,
        "created_at":            time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "total_files":           len(files),
        "parsed_files":          0,
        "all_nodes":             [],
        "dependencies":          [],
        "ghost_rule_candidates": [],
        "entry_points":          [],
        "language_summary":      {},
        "guardrail_findings":    [],
        "module_summaries":      {},   # ← new: LLM summary per file
        "business_domains":      {},   # ← new: LLM domain per file
    }

    # Build a lookup from file path → annotation
    # so we can merge Cell 5 results into the artifact
    annotation_lookup = {}
    for r in annotated_results:
        if "annotation" in r:
            annotation_lookup[r["language"]] = r  # temp — fix below

    # Better lookup — key by file path
    annotation_by_file = {}
    for r in annotated_results:
        if "annotation" in r:
            # find which file this result belongs to
            for rel_path in files:
                full = os.path.join(clone_dir, rel_path)
                try:
                    content = open(full, encoding="utf-8", errors="replace").read()
                    test    = parse_file(rel_path, content)
                    if (test["language"] == r["language"] and
                            test["lines"] == r["lines"]):
                        annotation_by_file[rel_path] = r["annotation"]
                        break
                except Exception:
                    continue

    for rel_path in files[:max_files]:
        full = os.path.join(clone_dir, rel_path)
        try:
            content = open(full, encoding="utf-8", errors="replace").read()
        except OSError:
            continue

        result = parse_file(rel_path, content)
        lang   = result["language"]
        nodes  = result["nodes"]

        artifact["parsed_files"] += 1
        artifact["guardrail_findings"].extend(result["guardrail_findings"])

        s = artifact["language_summary"].setdefault(
            lang, {"files": 0, "nodes": 0, "lines": 0}
        )
        s["files"] += 1
        s["nodes"] += len(nodes)
        s["lines"] += result["lines"]

        # Pull annotation for this file if it exists
        annotation = annotation_by_file.get(rel_path, {})

        # Build annotation lookup by node name for merging
        ann_by_name = {}
        if annotation:
            for a in annotation.get("annotations", []):
                ann_by_name[a["name"]] = a

            # Store file-level LLM outputs
            artifact["module_summaries"][rel_path] = annotation.get("module_summary", "")
            artifact["business_domains"][rel_path] = annotation.get("business_domain", "")

        for n in nodes:
            n["file"] = rel_path

            # Merge LLM annotation into the node
            ann = ann_by_name.get(n["name"], {})
            if ann:
                n["description"]      = ann.get("description", "")
                n["is_entry"]         = n.get("is_entry") or ann.get("is_entry_point", False)
                n["ghost_risk"]       = ann.get("ghost_rule_risk", n.get("ghost_risk", False))
                n["ghost_risk_reason"]= ann.get("ghost_rule_reason", "")
            else:
                n["description"]      = ""
                n["ghost_risk_reason"]= ""

            artifact["all_nodes"].append(n)

            if n.get("is_entry"):   artifact["entry_points"].append(n["name"])
            if n.get("ghost_risk"): artifact["ghost_rule_candidates"].append({
                "file":   rel_path,
                "reason": n.get("ghost_risk_reason", ""),
                **n
            })
            if n.get("type") in ("call_dep", "import"):
                artifact["dependencies"].append({"from": rel_path, "to": n["name"]})

    payload            = json.dumps(artifact, sort_keys=True, default=str)
    artifact["sha256"] = hashlib.sha256(payload.encode()).hexdigest()
    return artifact


