# The Auditor follows the call graph from entry points
# Dependencies in the structural map tell us what calls what

def build_call_graph(structural_map: dict) -> Dict[str, List[str]]:
    """
    Build adjacency: method_name → [list of methods it calls]
    Used to traverse from entry points through the full call chain.
    """
    graph = {}
    for dep in structural_map["dependencies"]:
        caller = dep.get("from", "")
        callee = dep.get("to", "")
        if caller and callee:
            graph.setdefault(caller, []).append(callee)
    return graph

def build_node_index(structural_map: dict) -> Dict[str, dict]:
    """Index all nodes by name for fast lookup."""
    return {n["name"]: n for n in structural_map["all_nodes"]}

