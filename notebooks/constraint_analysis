# The Auditor needs the actual source code to extract constraints
# The structural map tells us which file and line each node lives at
# This cell builds a cache of file contents for fast lookup

CLONE_DIR = "/tmp/exp_repo"   # same as Archeologist notebook

file_cache: Dict[str, str] = {}

def get_source(file_path: str) -> str:
    """Read and cache source file content."""
    if file_path not in file_cache:
        full = os.path.join(CLONE_DIR, file_path)
        try:
            file_cache[file_path] = open(full, encoding="utf-8", errors="replace").read()
        except OSError:
            file_cache[file_path] = ""
    return file_cache[file_path]

def extract_method_source(file_path: str, start_line: int, end_line: int = None, 
                           window: int = 40) -> str:
    """
    Extract source lines around a node.
    Uses end_line if available, otherwise takes a window of lines.
    """
    content = get_source(file_path)
    if not content:
        return ""
    lines = content.split("\n")
    start = max(0, start_line - 1)
    end   = min(len(lines), end_line if end_line else start_line + window)
    return "\n".join(f"{start_line + i:>4}  {line}" 
                     for i, line in enumerate(lines[start:end]))

