# Run constraint extraction across:
# 1. All entry points          — start of every execution path
# 2. All ghost rule candidates — highest risk nodes
# 3. High complexity nodes     — most likely to hide constraints

MAX_NODES = 15   # increase when comfortable with the output

# Priority queue — entry points first, then ghost risks, then high complexity
priority_nodes = []

# 1. Entry points
for name in structural_map["entry_points"]:
    node = node_index.get(name)
    if node:
        priority_nodes.append(("entry_point", node))

# 2. Ghost rule candidates
for g in structural_map["ghost_rule_candidates"]:
    if g["name"] not in [n["name"] for _, n in priority_nodes]:
        priority_nodes.append(("ghost_risk", g))

# 3. High complexity (complexity > 4) — fill remaining slots
for node in structural_map["all_nodes"]:
    if len(priority_nodes) >= MAX_NODES:
        break
    if (node.get("complexity", 0) > 4 and
            node["name"] not in [n["name"] for _, n in priority_nodes]):
        priority_nodes.append(("high_complexity", node))

print(f"Nodes selected for audit: {len(priority_nodes)}")
for reason, node in priority_nodes:
    print(f"  [{reason:<16}] {node['name']:<35} complexity={node.get('complexity','-')}")





# This is Artifact ② — the output of the Auditor agent
# Consumed by the Reconciler

constraint_model = {
    "artifact_id":       hashlib.md5(f"auditor-{time.time()}".encode()).hexdigest()[:12],
    "source_artifact_id": structural_map["artifact_id"],
    "repo_url":          structural_map["repo_url"],
    "created_at":        time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    "nodes_audited":     0,
    "total_constraints": 0,
    "ghost_rules":       [],
    "vendor_assumptions":[],
    "critical_nodes":    [],
    "constraint_map":    {},   # node_name → full constraint result
    "summary": {
        "by_type":        {},
        "by_confidence":  {},
        "by_risk":        {},
    }
}

print(f"Running Auditor on {len(priority_nodes)} nodes...\n")

for reason, node in priority_nodes:
    lang = get_language(node["file"])
    print(f"{'─'*65}")
    print(f"📋 {node['name']}  [{reason}]  file={node['file']}")

    result = extract_constraints(node, lang)

    if not result:
        print(f"   ⚠️  No constraints extracted")
        continue

    # Store in constraint map
    constraint_model["constraint_map"][node["name"]] = {
        "node":        node,
        "language":    lang,
        "audit_result":result,
        "audit_reason":reason,
    }

    constraint_model["nodes_audited"] += 1
    constraints = result.get("constraints", [])
    constraint_model["total_constraints"] += len(constraints)

    # Collect ghost rules
    for c in constraints:
        if c.get("is_ghost_rule"):
            constraint_model["ghost_rules"].append({
                "node":       node["name"],
                "file":       node["file"],
                "constraint": c["statement"],
                "reason":     c.get("ghost_reason", ""),
                "confidence": c["confidence"],
            })

    # Collect vendor assumptions
    for c in constraints:
        if c.get("assumes_vendor_behaviour"):
            constraint_model["vendor_assumptions"].append({
                "node":   node["name"],
                "file":   node["file"],
                "detail": c.get("vendor_assumption_detail", ""),
                "constraint": c["statement"],
            })

    # Collect critical nodes
    if result.get("overall_risk") == "critical":
        constraint_model["critical_nodes"].append(node["name"])

    # Summary counts
    for c in constraints:
        t = c.get("type", "unknown")
        constraint_model["summary"]["by_type"][t] = \
            constraint_model["summary"]["by_type"].get(t, 0) + 1
        conf = c.get("confidence", "unknown")
        constraint_model["summary"]["by_confidence"][conf] = \
            constraint_model["summary"]["by_confidence"].get(conf, 0) + 1

    risk = result.get("overall_risk", "unknown")
    constraint_model["summary"]["by_risk"][risk] = \
        constraint_model["summary"]["by_risk"].get(risk, 0) + 1

    # Print summary for this node
    print(f"   Risk         : {result.get('overall_risk')}")
    print(f"   Constraints  : {len(constraints)}")
    print(f"   Ghost rules  : {sum(1 for c in constraints if c.get('is_ghost_rule'))}")
    print(f"   Vendor deps  : {sum(1 for c in constraints if c.get('assumes_vendor_behaviour'))}")
    print(f"   Side effects : {result.get('side_effects', [])}")

