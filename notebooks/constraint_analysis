# This is the core of the Auditor agent
# For each node it sends the actual source to Gemini
# and asks for formal constraints — not descriptions

CONSTRAINT_PROMPT = f"""You are the Auditor agent in a legacy payments modernisation pipeline.

Your job is to extract every business rule and constraint from this code
expressed in language-agnostic form — completely independent of the programming language.

File        : {file_path}
Language    : {language}
Method/Unit : {method_name}
Description : {description}
Ghost Risk  : {ghost_risk}
Ghost Reason: {ghost_reason}

Source code:

{source_code}

Extract ALL constraints this code enforces. For each constraint provide:
{{
  "constraints": [
    {{
      "id":           "C001",
      "type":         "validation | business_rule | error_handling | temporal | state_transition | security",
      "statement":    "plain English rule e.g. amount MUST be greater than zero",
      "condition":    "the condition being checked",
      "violation":    "what happens if this constraint is violated",
      "confidence":   "certain | probable | suspected",
      "is_ghost_rule": true/false,
      "ghost_reason": "why this is a ghost rule or null",
      "assumes_vendor_behaviour": true/false,
      "vendor_assumption_detail": "what vendor specific behaviour this assumes or null"
    }}
  ],
  "entry_point":       true/false,
  "has_side_effects":  true/false,
  "side_effects":      ["list of side effects e.g. writes to DB, publishes to queue"],
  "calls_external":    true/false,
  "external_systems":  ["list of external systems called"],
  "overall_risk":      "low | medium | high | critical",
  "auditor_notes":     "any important observations for the modernisation team"
}}

Respond ONLY with valid JSON. No markdown fences."""


def extract_constraints(node: dict, language: str) -> Optional[dict]:
    """
    Core Auditor function.
    Takes one node from the structural map, reads its source,
    and extracts formal constraints via Gemini.
    """
    source = extract_method_source(
        node["file"], node["line"],
        end_line=node.get("end_line"),
        window=50
    )
    if not source.strip():
        return None

    prompt = CONSTRAINT_PROMPT.format(
        file_path   = node["file"],
        language    = language,
        method_name = node["name"],
        description = node.get("description", "Not available"),
        ghost_risk  = node.get("ghost_risk", False),
        ghost_reason= node.get("ghost_risk_reason", "None"),
        source_code = source,
    )

    try:
        response = model.generate_content(prompt, generation_config=gen_config)
        text = response.text.strip()
        text = re.sub(r"^```(?:json)?\s*\n?", "", text)
        text = re.sub(r"\n?```\s*$", "", text)
        return json.loads(text)
    except Exception as e:
        print(f"  ❌ Error for {node['name']}: {e}")
        return None


