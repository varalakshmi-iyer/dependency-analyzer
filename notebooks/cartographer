# Critical path — longest synchronous chain through the graph
# Blast radius — shared service impact analysis
# Both run identically in both modes

def find_critical_path(nodes: List[dict],
                        edges: List[dict]) -> List[str]:
    """Longest synchronous chain from any initiator node."""
    node_ids   = {n["node_id"] for n in nodes}
    all_targets = {e["target"] for e in edges if e["is_synchronous"]}
    initiators  = [n["node_id"] for n in nodes
                   if n["node_id"] not in all_targets]
    if not initiators:
        initiators = [nodes[0]["node_id"]] if nodes else []

    adj: Dict[str, List[str]] = {n["node_id"]: [] for n in nodes}
    for e in edges:
        if e["is_synchronous"] and e["source"] in adj:
            adj[e["source"]].append(e["target"])

    best = []

    def dfs(node_id, path, visited):
        nonlocal best
        if len(path) > len(best):
            best = list(path)
        for neighbour in adj.get(node_id, []):
            if neighbour not in visited:
                dfs(neighbour, path + [neighbour], visited | {neighbour})

    for initiator in initiators:
        dfs(initiator, [initiator], {initiator})

    # Mark critical path edges
    for edge in edges:
        if (edge["source"] in best and edge["target"] in best):
            edge["is_critical_path"] = True

    return best


def analyse_blast_radius(nodes:          List[dict],
                          semantic_map:   dict,
                          mode:           str) -> List[dict]:
    """
    In both modes: flag shared services.
    In modernisation mode: also flag nodes whose ghost rules
    affect downstream dependencies.
    """
    risks = []
    ghost_nodes = {g["node"] for g in
                   constraint_model.get("ghost_rules", [])}

    for node in nodes:
        if node.get("is_vendor"):
            continue

        # Check if globally shared (multi-repo — from repo input metadata)
        # In single-repo notebook we simulate with ghost rule count
        is_high_risk = node.get("ghost_rule_count", 0) > 0

        if is_high_risk:
            if mode == "code_modernisation":
                risks.append({
                    "service_id":   node["node_id"],
                    "service_name": node["node_name"],
                    "risk_type":    "ghost_rule_blast_radius",
                    "risk_level":   "HIGH",
                    "detail":       (
                        f"{node['ghost_rule_count']} ghost rule(s) — "
                        f"if semantics break during modernisation, "
                        f"all callers of this service are affected"
                    ),
                    "recommended_action": (
                        "Resolve ghost rules before modernising. "
                        "Add characterisation tests first."
                    ),
                })
            else:
                risks.append({
                    "service_id":   node["node_id"],
                    "service_name": node["node_name"],
                    "risk_type":    "integration_blast_radius",
                    "risk_level":   "HIGH",
                    "detail":       (
                        "Service has ghost rules at processor integration boundary. "
                        "Migration may silently break behaviour."
                    ),
                    "recommended_action": "SME review before migration delta applied.",
                })

    return risks


