                "Write characterisation tests before modernising callers."
                if len(all_callers) > 0
                else "PRESERVE_EXACTLY — isolated ghost rule, lower blast radius."
            ),
        }
        ghost_dependency_chains.append(chain)

    print(f"Ghost rule dependency chains: {len(ghost_dependency_chains)}\n")
