            dep.get("from","") for dep in structural_map.get("dependencies",[])
            if dep.get("to","") == ghost_name
        ]
        all_callers = list(set(callers + direct_callers))

        chain = {
            "ghost_rule_node":  ghost_name,
            "file":             ghost_info.get("file",""),
            "constraint":       ghost_info.get("constraint",""),
            "confidence":       ghost_info.get("confidence",""),
            "direct_callers":   all_callers,
