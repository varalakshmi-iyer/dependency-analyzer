# Edges represent cross-service calls and vendor integrations
# In migration mode: includes service → Processor A/B edges
# In modernisation mode: service → service edges only

def build_workflow_edges(structural_map: dict,
                          semantic_map:  dict,
                          mode:          str) -> List[dict]:
    edges = []
    seen  = set()

    def add_edge(source, target, pattern, sync=True,
                 msg_format=None, sla=None, evidence=None):
        key = f"{source}→{target}:{pattern}"
        if key in seen:
            return
        seen.add(key)
        edges.append({
            "edge_id":       hashlib.md5(key.encode()).hexdigest()[:10],
            "source":        source,
            "target":        target,
            "pattern":       pattern,
            "is_synchronous":sync,
            "message_format":msg_format,
            "sla_seconds":   sla,
            "evidence":      evidence,
            "is_critical_path": False,  # set in Cell 6
        })

    # ── Cross-service edges from dependency graph ──────────────────
    for dep in structural_map.get("dependencies", []):
        src = dep.get("from", "")
        tgt = dep.get("to", "")
        if src and tgt and src != tgt:
            add_edge("primary", "primary",  # same service in single-repo mode
                     "internal_call", evidence=f"{src}→{tgt}")

    # ── Vendor integration edges — migration mode only ─────────────
    if mode == "processor_migration":
        proc_a = semantic_map.get("processor_a_profile") or {}
        proc_b = semantic_map.get("processor_b_profile") or {}

        for ip in proc_a.get("integration_points", []):
            add_edge(
                source     = "primary",
                target     = proc_a.get("processor_id", "processor_a"),
                pattern    = ip.get("pattern", "rest_api"),
                sync       = ip.get("is_synchronous", True),
                msg_format = ip.get("message_format"),
                sla        = ip.get("sla_seconds"),
                evidence   = ip.get("endpoint"),
            )

        # Migration delta edges — show what changes
        delta = semantic_map.get("migration_delta") or {}
        for ip in delta.get("new_integration_points", []):
            add_edge(
                source  = "primary",
                target  = proc_b.get("processor_id", "processor_b"),
                pattern = ip.get("pattern", "rest_api"),
                sla     = ip.get("sla_seconds"),
                evidence= f"NEW: {ip.get('operation','')}",
            )

    return edges


