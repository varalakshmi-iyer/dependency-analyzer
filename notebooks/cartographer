def run_cartographer_llm(mode, workflow_nodes, workflow_edges,
                          critical_path, blast_radius,
                          ghost_dependency_chains, semantic_map):
    ma    = semantic_map.get("modernisation_assessment") or {}
    delta = semantic_map.get("migration_delta") or {}

    nodes_text = "\n".join(
        f"  {n['node_id']} [{n['node_type']}] "
        f"status={n.get('modernisation_status') or n.get('migration_status','?')}"
        for n in workflow_nodes
    )
    blast_text = "\n".join(
        f"  {r['service_name']}: {r['detail']}"
        for r in blast_radius
    ) or "None"
    temporal_text = "\n".join(
        f"  {t['node']}: {t['code_assumption']} → {t['action']}"
        for t in semantic_map.get("temporal_at_risk", [])[:10]
    ) or "None"

    if mode == "processor_migration":
        prompt = CARTOGRAPHER_PROMPT_MIGRATION.format(
            nodes       = nodes_text,
            edge_count  = len(workflow_edges),
            critical_path = " → ".join(critical_path) or "single node",
            blast_radius = blast_text,
            changed     = len(delta.get("changed_integration_points",[])),
            removed     = len(delta.get("removed_integration_points",[])),
            new         = len(delta.get("new_integration_points",[])),
            unchanged   = len(delta.get("unchanged_integration_points",[])),
            complexity  = delta.get("overall_complexity","unknown"),
            temporal    = temporal_text,
        )
    else:
        node_status_text = "\n".join(
            f"  {n['node_id']}: {n.get('modernisation_status','BLUE')}"
            for n in workflow_nodes if not n.get("is_vendor")
        )
        ghost_text = "\n".join(
            f"  {c['ghost_rule_node']} [{c['risk_level']}] "
            f"blast={c['blast_radius']} callers"
            for c in ghost_dependency_chains
        ) or "None"
        debt_text = "\n".join(
            f"  {t.get('location','?')}: {t.get('description','')[:60]}"
            for t in ma.get("tech_debt_found", [])[:8]
        ) or "None"

        prompt = CARTOGRAPHER_PROMPT_MODERNISATION.format(
            nodes        = nodes_text,
            edge_count   = len(workflow_edges),
            critical_path= " → ".join(critical_path) or "single node",
            node_status  = node_status_text,
            ghost_chains = ghost_text,
            blast_radius = blast_text,
            tech_debt    = debt_text,
            temporal     = temporal_text,
        )

    try:
        response = model.generate_content(prompt, generation_config=gen_config)
        raw = response.text.strip()
        raw = re.sub(r"^```(?:json)?\s*\n?", "", raw)
        raw = re.sub(r"\n?```\s*$", "", raw)
        return json.loads(raw)
    except Exception as e:
        print(f"❌ LLM error: {e}")
        return None


