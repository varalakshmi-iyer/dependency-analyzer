def get_node_status_modernisation(service_name: str,
                                   modernisation_assessment: dict) -> str:
    """
    In modernisation mode, each node gets a status:
    GREEN  = safe to modernise
    RED    = must preserve exactly (ghost rule)
    AMBER  = needs documentation first
    BLUE   = no assessment — treat as unknown
    """
    safe  = [s["node"] for s in
              modernisation_assessment.get("safe_to_modernise", [])]
    exact = [s["node"] for s in
              modernisation_assessment.get("must_preserve_exactly", [])]
    doc   = [s["node"] for s in
              modernisation_assessment.get("needs_documentation_first", [])]

    if service_name in exact: return "RED"
    if service_name in doc:   return "AMBER"
    if service_name in safe:  return "GREEN"
    return "BLUE"


def build_workflow_nodes(structural_map: dict,
                          semantic_map: dict,
                          mode: str) -> List[dict]:
    nodes = []
    ma = semantic_map.get("modernisation_assessment") or {}
    services_requiring_changes = semantic_map.get("services_requiring_changes", [])
    services_untouched         = semantic_map.get("services_untouched", [])

    # ── Service nodes — always built ──────────────────────────────
    # In the notebook we have one repo so one primary service
    # In production this loops over all N repos in the workflow
    lang_summary = structural_map.get("language_summary", {})
    languages    = list(lang_summary.keys())

    primary_service = {
        "node_id":          "primary",
        "node_name":        structural_map["repo_url"].split("/")[-1],
        "node_type":        "service",
        "is_vendor":        False,
        "is_globally_shared": False,
        "languages":        languages,
        "entry_points":     structural_map.get("entry_points", []),
        "ghost_rule_count": len(structural_map.get("ghost_rule_candidates", [])),
        "node_role":        "primary_service",
    }

    # Overlay mode-specific status
    if mode == "code_modernisation":
        primary_service["modernisation_status"] = get_node_status_modernisation(
            "primary", ma
        )
        primary_service["requires_changes"] = True  # whole service being modernised
        primary_service["migration_status"]  = None
    else:
        primary_service["modernisation_status"] = None
        primary_service["requires_changes"] = "primary" in services_requiring_changes
        primary_service["migration_status"]  = (
            "requires_changes" if "primary" in services_requiring_changes
            else "untouched"
        )

    nodes.append(primary_service)

    # ── Vendor nodes — migration mode only ────────────────────────
    if mode == "processor_migration":
        proc_a = semantic_map.get("processor_a_profile")
        proc_b = semantic_map.get("processor_b_profile")

        if proc_a:
            nodes.append({
                "node_id":   proc_a["processor_id"],
                "node_name": proc_a["processor_name"],
                "node_type": "vendor",
