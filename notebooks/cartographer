                "role":      "source — being replaced",
                "integration_points": len(proc_a.get("integration_points", [])),
                "auth":      proc_a.get("auth_mechanisms", []),
                "protocols": proc_a.get("supported_protocols", []),
                "modernisation_status": None,
                "migration_status": "being_replaced",
            })

        if proc_b:
            nodes.append({
                "node_id":   proc_b["processor_id"],
                "node_name": proc_b["processor_name"],
                "node_type": "vendor",
                "is_vendor": True,
                "role":      "target — replacement",
                "integration_points": len(proc_b.get("integration_points", [])),
                "auth":      proc_b.get("auth_mechanisms", []),
                "protocols": proc_b.get("supported_protocols", []),
                "modernisation_status": None,
                "migration_status": "incoming",
            })

    return nodes


